#!/bin/sh

# Chemins acme.sh
ACME_SH="/root/.acme.sh/acme.sh"

# Renouvellement TLS-ALPN-01 sur le port interne dedie 5443
# (HAProxy redirige les validations ACME vers ce port, nginx continue
# de servir l'application normalement sur son port habituel)
${ACME_SH} --renew-all --alpn --standalone --tlsport 5443 --server letsencrypt
