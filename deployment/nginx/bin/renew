#!/bin/sh

# Chemins acme.sh
ACME_SH="/root/.acme.sh/acme.sh"

# Renouveler via TLS-ALPN-01 sur le port interne 5443
# (le bloc stream de nginx redirige les validations ACME vers ce port,
# nginx continue de servir l'application sur le 443 sans interruption)
${ACME_SH} --renew-all --alpn --standalone --tlsport 5443 --server letsencrypt
